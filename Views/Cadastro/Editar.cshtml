@model CadastroViewModel
@{
    ViewData["Title"] = "Editar cadastro";
}
<style>
    .form-container {
        width: 100%;
        padding: 0.1rem;
        border: 1px solid #ccc;
        border-radius: 10px; /* opcional: remove o arredondamento se quiser bordas quadradas */
        box-sizing: border-box; /* garante que padding não estoure a largura */
        background-color: rgba(248, 249, 250, 0);
    }
    /*
                .custom-border {
                    border-bottom: 2px solid black;
                    padding: 0.25rem;
                } */

    .form-group-spacing {
        margin-bottom: 2rem; /* Triplo do padrão (~1.33rem) */
    }

    #table-usuarios {
        table-layout: auto !important;
        width: auto !important;
    }

        #table-usuarios th,
        #table-usuarios td {
            white-space: nowrap; /* impede quebra de linha */
            font-size: 12px; /* já reduz o tamanho da fonte */
            padding: 4px 8px; /* opcional: deixa a célula mais compacta */
            color: rgba(0,0,0); /* branco */
        }

        #table-usuarios thead th {
            color: rgba(0,0,0); /* branco esverdeado */
            font-weight: 600;
        }

    .icon-mini {
        font-size: 1.05rem; /* ~12px */
    }

        .icon-mini:hover {
            border-color: #fff; /* borda branca no hover */
            cursor: pointer; /* muda o cursor para indicar clique */
        }

    .botao-transparente {
        background-color: transparent;
        border: 1px solid transparent;
        color: #fff; /* cor do ícone branco */
    }

        .botao-transparente:hover {
            border-color: #fff; /* cor do ícone branco */
            background-color: rgba(0, 0, 0, 0.05);
        }
    /* reset simples */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        height: 100%;
    }


    /* BOTÃO NAV */
    .btn-nav {
        padding: 6px 14px;
        border-radius: 10px;
        display: inline-block;
        width: 100%;
        text-align: center;
        font-weight: 600;
        border: 1px solid rgba(230,243,234,0.3);
        backdrop-filter: blur(6px);
        background: linear-gradient(90deg, rgba(70,200,120,0.1), rgba(50,160,90,0.14));
        color: #fff;
        cursor: pointer;
        transition: background 0.3s ease, color 0.3s ease;
    }

        .btn-nav:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }

    /* Formulário */
    .form-container {
        width: 100%;
        margin: 0;
        padding: 0.5rem;
        border-radius: 10px;
        background-color: transparent;
        box-sizing: border-box;
    }

    .form-group-spacing {
        margin-bottom: 2rem;
    }

    /* HERO (conteúdo em primeiro plano) */
    .hero {
        min-height: 72vh;
        display: flex;
        align-items: center;
        position: relative;
        z-index: 1;
        padding: 60px 40px;
    }

    .hero-inner {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 32px;
        position: relative;
        z-index: 3;
    }

    .hero h1 {
        font-size: 48px;
        line-height: 1.02;
        margin-bottom: 12px;
        color: #e9fff1;
        text-shadow: 0 6px 22px rgba(2,10,6,0.5);
    }

    .hero .accent {
        color: #48c878;
    }

    .lead {
        color: rgba(230,243,234,0.8);
        margin-bottom: 18px;
    }

    .hero-cta {
        display: flex;
        gap: 12px;
        margin-bottom: 22px;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(6px);
    }

        .btn:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }

        .btn.primary {
            background: linear-gradient(90deg, rgba(70,200,120,0.18), rgba(50,160,90,0.14));
            color: #eaffef;
        }

            .btn.primary:hover {
                background: rgba(70,200,120,0.18);
                color: #fff;
            }

        .btn.ghost {
            background: transparent;
            color: rgba(230,243,234,0.9);
            border: 1px solid rgba(230,243,234,0.08);
        }

            .btn.ghost:hover {
                background: rgba(255,255,255,0.05);
                color: #fff;
            }

    /* cards */
    .cards {
        display: flex;
        gap: 14px;
        margin-top: 18px;
    }

    .card {
        min-width: 200px;
        padding: 14px;
        border-radius: 12px;
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.12));
        box-shadow: 0 8px 24px rgba(2,10,6,0.45);
        backdrop-filter: blur(6px);
        color: #dff7e8;
    }

    /* rodapé */
    .site-footer {
        padding: 24px;
        text-align: center;
        color: rgba(200,230,210,0.6);
    }

    /* responsividade simples */
    @@media (max-width:900px) {
        .hero h1 {
            font-size: 32px;
        }

        .nav-links {
            display: none;
        }

        .hero {
            padding: 30px;
        }

        .cards {
            flex-direction: column;
        }
    }

    /* textbox */
    .textbox {
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 400;
        border: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(6px);
        background: transparent;
        color: #fff;
        font-family: inherit;
        font-size: 16px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.3s ease;
    }

        /* placeholder */
        .textbox::placeholder {
            color: rgba(255,255,255,0.5);
        }

        /* foco */
        .textbox:focus {
            outline: none;
            border: 1px solid #48c878;
            box-shadow: 0 0 12px rgba(72,200,120,0.3);
        }

    /* autocomplete transparente Chrome/Safari */
    input.textbox:-webkit-autofill,
    input.textbox:-webkit-autofill:hover,
    input.textbox:-webkit-autofill:focus,
    input.textbox:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0px 1000px transparent inset !important;
        -webkit-text-fill-color: #fff !important;
        transition: background-color 5000s ease-in-out 0s;
    }

    /* autocomplete transparente Firefox */
    input.textbox:-moz-autofill {
        box-shadow: 0 0 0px 1000px transparent inset !important;
        -moz-text-fill-color: #fff !important;
    }

    /* link verde */
    .link-green {
        color: #48c878;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        transition: color 0.3s ease;
    }

        .link-green:hover {
            color: #32a060;
        }

    /* Combobox estilo igual ao textbox */
    .selectbox {
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 400;
        border: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(6px);
        background: transparent;
        color: #fff;
        font-family: inherit;
        font-size: 16px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.3s ease;
        appearance: none; /* remove a setinha padrão */
        -webkit-appearance: none; /* Safari/Chrome */
        -moz-appearance: none; /* Firefox */
        cursor: pointer;
    }

        /* Ícone de seta customizado */
        .selectbox::-ms-expand {
            display: none; /* remove seta no IE */
        }

        /* Opções do dropdown */
        .selectbox option {
            background-color: rgba(20, 20, 20, 0.95); /* fundo escuro */
            color: #fff; /* texto branco */
        }

        /* Foco */
        .selectbox:focus {
            outline: none;
            border: 1px solid #48c878;
            box-shadow: 0 0 12px rgba(72,200,120,0.3);
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<div class="text-center">

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>
    }
</div>

<div class="form-container">

    <div class="text-center mb-4">
        <h1 class="fs-3 custom-border d-inline-block">Editar cadastro</h1>
    </div>
    <form asp-controller="Cadastro" asp-action="Editar" method="post" class="form-horizontal">
        <input type="hidden" asp-for="CadastroNome.Id" />

        <div class="row form-group-spacing align-items-center">
            <div class="row form-group-spacing">
                <label class="col-12 col-sm-4 col-form-label text-sm-end">Nome</label>
                <div class="col-12 col-sm-6">
                    <input type="text" asp-for="CadastroNome.Nome" class="textbox" placeholder="Digite o nome" />
                    @Html.ValidationMessageFor(x => x.CadastroNome.Nome)
                </div>
            </div>

            <div class="row form-group-spacing">
                <label class="col-12 col-sm-4 col-form-label text-sm-end">Nascimento</label>
                <div class="col-12 col-sm-6">
                    <input type="date" asp-for="CadastroNome.Nascimento" class="textbox" />
                    @Html.ValidationMessageFor(x => x.CadastroNome.Nascimento)
                </div>
            </div>

            <div class="row form-group-spacing">
                <label class="col-12 col-sm-4 col-form-label text-sm-end">Documento</label>
                <div class="col-12 col-sm-6">
                    <input type="text" asp-for="CadastroNome.Documento" class="textbox" placeholder="Digite o nr do documento" />
                    @Html.ValidationMessageFor(x => x.CadastroNome.Documento)
                </div>
            </div>

            <div class="row form-group-spacing">
                <label class="col-12 col-sm-4 col-form-label text-sm-end">Contacto</label>
                <div class="col-12 col-sm-6">
                    <input type="text" asp-for="CadastroNome.Contacto" class="textbox" placeholder="Digite o contacto" />
                    @Html.ValidationMessageFor(x => x.CadastroNome.Contacto)
                </div>
            </div>

            <div class="row form-group-spacing align-items-center">
                <label class="col-12 col-sm-4 col-form-label text-sm-end"></label>
                <div class="col-12 col-sm-8 d-flex flex-wrap gap-3">
                    <div class="d-flex flex-column text-center">
                        <label class="form-label mb-1">Contribuinte</label>
                        <select asp-for="CadastroNome.Contribuinte" class="selectbox">
                            <option value="false">Não</option>
                            <option value="true">Sim</option>
                        </select>
                        @Html.ValidationMessageFor(x => x.CadastroNome.Contribuinte)
                    </div>

                    <div class="d-flex flex-column text-center">
                        <label class="form-label mb-1">Obreiro</label>
                        <select asp-for="CadastroNome.Obreiro" class="selectbox">
                            <option value="false">Não</option>
                            <option value="true">Sim</option>
                        </select>
                        @Html.ValidationMessageFor(x => x.CadastroNome.Obreiro)
                    </div>

                    <div class="d-flex flex-column text-center">
                        <label class="form-label mb-1">Cliente</label>
                        <select asp-for="CadastroNome.Cliente" class="selectbox">
                            <option value="false">Não</option>
                            <option value="true">Sim</option>
                        </select>
                        @Html.ValidationMessageFor(x => x.CadastroNome.Cliente)
                    </div>

                    <div class="d-flex flex-column text-center">
                        <label class="form-label mb-1">Fornecedor</label>
                        <select asp-for="CadastroNome.Fornecedor" class="selectbox">
                            <option value="false">Não</option>
                            <option value="true">Sim</option>
                        </select>
                        @Html.ValidationMessageFor(x => x.CadastroNome.Fornecedor)
                    </div>

                    <div class="d-flex flex-column text-center">
                        <label class="form-label mb-1">Professor</label>
                        <select asp-for="CadastroNome.Professor" class="selectbox">
                            <option value="false">Não</option>
                            <option value="true">Sim</option>
                        </select>
                        @Html.ValidationMessageFor(x => x.CadastroNome.Professor)
                    </div>
                </div>
            </div>

            <!-- Tabernáculo -->
           @*  <div class="row form-group-spacing">
                <label class="col-12 col-sm-4 col-form-label text-sm-end">Tabernáculo</label>
                <div class="col-12 col-sm-6">
                    <select asp-for="CadastroNome.TabernaculoId" asp-items="Model.CadastroNome.ListaAgencias" class="selectbox">
                        <option value="">-- Selecione --</option>
                    </select>
                    @Html.ValidationMessageFor(x => x.CadastroNome.TabernaculoId)
                </div>
            </div> *@

            <!-- Estado -->
          @*   <div class="row form-group-spacing">
                <label class="col-12 col-sm-4 col-form-label text-sm-end">Estado</label>
                <div class="col-12 col-sm-6">
                    <select asp-for="CadastroNome.EstadoId" asp-items="Model.CadastroNome.ListaEstados" class="selectbox">
                        <option value="">-- Selecione --</option>
                    </select>
                    @Html.ValidationMessageFor(x => x.CadastroNome.EstadoId)
                </div>
            </div> *@
            <!-- Botões ocupam 4 colunas -->
            <div class="d-flex justify-content-between mt-5">
                <a class="btn ghost" asp-controller="Cadastro" asp-action="Criar" role="button">Voltar</a>
                <button type="submit" class="btn primary">Salvar alterações</button>
            </div>
        </div>
    </form>
</div>