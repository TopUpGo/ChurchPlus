@model LoginModel
@{
    Layout = "_Layout_Deslogado";
    ViewData["Title"] = "Redefinir Senha";
}

<style>
    .form-container {
        width: 100%;
        margin: 0;
        padding: 1rem;
        border: 0px solid #ccc;
        border-radius: 10px;
        background-color: rgba(248, 249, 250, 0);
        box-sizing: border-box;
    }

    .form-container1 {
        width: 100%;
        margin: 0;
        padding: 0.5rem;
        border: 0px solid #ccc;
        border-top-left-radius: 0px;
        border-top-right-radius: 0px;
        border-bottom-left-radius: 8px;
        border-bottom-right-radius: 8px;
        background-color: rgba(248, 249, 250, 0);
        box-sizing: border-box;
    }

    .form-group-spacing {
        margin-bottom: 0.5rem;
    }

    .section-header {
        background-color: #3C4043;
        color: white;
        padding: 0.5rem;
        margin: 0;
        border-top-left-radius: 0px;
        border-top-right-radius: 0px;
        border-bottom-left-radius: 0px;
        border-bottom-right-radius: 0px;
        font-weight: bold;
        display: block;
    }

    .bank-entry-container {
        display: flex;
        justify-content: center; /* centraliza o botão se houver espaço */
        border: 1px solid #29b6b6;
        border-radius: 6px;
        padding: 1rem;
        margin-top: 2rem;
        color: black;
    }

    .add-entry {
        width: 100%; /* ocupa toda a largura do container */
        max-width: 98%; /* deixa pouca margem lateral */
        text-align: center;
        cursor: pointer;
        color: black;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border-left: 1px dashed #29b6b6;
        transition: background-color 0.3s ease;
        padding: 1rem;
        box-sizing: border-box;
    }

        .add-entry:hover {
            background-color: #e0f7f7;
        }

    .plus-sign {
        font-size: 2rem;
        line-height: 1;
    }

    .add-text {
        font-size: 0.9rem;
        margin-top: 0.2rem;
    }

    .section-header1 {
        background-color: transparent;
        color: black;
        padding: 0.5rem;
        margin: 0;
        border-top-left-radius: 0px;
        border-top-right-radius: 0px;
        border-bottom-left-radius: 0px;
        border-bottom-right-radius: 0px;
        font-weight: bold;
        display: block;
    }

    .form-container2 {
        width: 100%;
        margin: 0;
        padding: 0.5rem;
        border: 0px solid #ccc;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
        border-bottom-left-radius: 8px;
        border-bottom-right-radius: 8px;
        background-color: rgba(248, 249, 250, 0);
        box-sizing: border-box;
    }

    .modal {
        display: none;
        position: fixed;
        z-index: 9999;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
    }

        .modal.show {
            display: block;
        }

    .modal-content {
        background-color: white;
        border-radius: 8px;
        margin: 10% auto;
        padding: 1rem;
        width: 100%;
        max-width: 500px;
    }

    .btn-close {
        background: none;
        border: none;
        font-size: 1.4rem;
        float: right;
    }
</style>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
<div class="text-center">

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>
    }
</div>
<h1 style="font-size: 20px;margin-top: 60px;">Redefinir Senha</h1>

<br />
@if (TempData["MensagemErro"] != null)
{
    <div class="alert alert-danger" role="alert">
        <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
        @TempData["MensagemErro"]
    </div>
}
<form asp-controller="Login" asp-action="EnviarLinkParaRedefinirSenha" method="post">
    <div class="row form-group-spacing">
        <label class="col-12 col-sm-3 col-form-label text-sm-end">Login</label>
        <div class="col-12 col-sm-6">
            <input type="text" asp-for="Login" class="form-control" placeholder="Qual é o login" id="Login" />
            @Html.ValidationMessageFor(x => x.Login)
        </div>
    </div>

    <div class="row form-group-spacing" style="display: none;">
        <label class="col-12 col-sm-3 col-form-label text-sm-end">Email</label>
        <div class="col-12 col-sm-6">
            <input type="text" asp-for="Email" class="form-control" placeholder="Digite email" id="Email" readonly />
            @Html.ValidationMessageFor(x => x.Email)
        </div>
    </div>

    <div class="row form-group-spacing">
        <div class="col-12 col-sm-6 offset-sm-3">
            <div id="mensagemUsuario" style="font-weight:bold; margin-bottom:10px;"></div>
        </div>
    </div>

    
    <a class="btn btn-outline-dark " asp-controller="Login" asp-action="Index" role="button">Voltar</a>
    <a class="btn btn-outline-dark" id="btnVerificar" role="button">Verificar os dados</a>
    <button type="submit" class="btn btn-dark text-center" id="btnRedefinir" disabled>Redefinir senha</button>
</form>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $("#btnVerificar").on("click", function (e) {
            e.preventDefault();

            var login = $("#Login").val().trim();
            if (login.length === 0) {
                alert("Por favor, insira um login.");
                return;
            }

            $.get("/Login/ObterEmailPorLogin", { login: login }, function (res) {
                if (res.sucesso) {
                    $("#Email").val(res.email);
                    $("#mensagemUsuario").text("✅ Usuário verificado").css("color", "green");
                    $("#btnRedefinir").prop("disabled", false);
                } else {
                    $("#Email").val("");
                    $("#mensagemUsuario").text("❌ Usuário não encontrado").css("color", "red");
                    $("#btnRedefinir").prop("disabled", true);
                }
            });
        });
    });
</script>