@model List<Analise.Models.TicketModel>

@{
    ViewData["Title"] = "Tickets";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.5/css/jquery.dataTables.min.css">

<div class="text-center">
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" aria-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" aria-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>
    }
</div>

<div class="form-container mb-4">
    <h1 class="fs-3 text-center mb-3">Tickets</h1>

    <!-- FORMULÁRIO DE FILTROS -->
    <form method="get" class="row g-3 align-items-end mb-4">
        <div class="col-md-3">
            <label for="estado" class="form-label">Estado</label>
            @Html.DropDownList("estado", (SelectList)ViewBag.Estados, "Todos", new { @class = "form-select" })
        </div>

        <div class="col-md-3">
            <label for="dataInicio" class="form-label">Data Início</label>
            <input type="date" name="dataInicio" id="dataInicio" class="form-control"
                   value="@ViewBag.DataInicio" />
        </div>

        <div class="col-md-3">
            <label for="dataFim" class="form-label">Data Fim</label>
            <input type="date" name="dataFim" id="dataFim" class="form-control"
                   value="@ViewBag.DataFim" />
        </div>

        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/Ticket/Index" class="btn btn-secondary">Limpar</a>
        </div>
    </form>

    <table class="table" id="table-usuarios">
        <thead>
            <tr>
                <th scope="col">Id</th>
                <th scope="col">Usuário</th>
                <th scope="col">Título</th>
                <th scope="col">Estado</th>
                <th scope="col">Data</th>
                <th scope="col"></th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var ticket in Model)
                {
                    <tr>
                        <th scope="row">@ticket.Id</th>
                        <td>@(ticket.Usuario ?? "Sem usuário")</td>
                        <td>@(ticket.Assunto ?? "Sem título")</td>
                        <td>@(ticket.Estado ?? "-")</td>
                        <td>@ticket.DataCriacao.ToString("yyyy-MM-dd")</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a role="button"
                                   class="btn botao-transparente btn-sm"
                                   asp-route-id="@ticket.Id"
                                   asp-controller="Ticket"
                                   asp-action="Editar"
                                   title="Editar">
                                    <i class="fa-solid fa-pen-to-square icon-mini"></i>
                                </a>
                            </div>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a role="button"
                                   class="btn botao-transparente btn-sm"
                                   asp-route-id="@ticket.Id"
                                   asp-controller="Ticket"
                                   asp-action="Visualizar"
                                   title="Visualizar">
                                    <i class="fa-solid fa-eye icon-mini"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr class="odd"><td valign="top" colspan="7" class="text-center">Nenhum ticket encontrado</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- SCRIPTS -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js"></script>
<script>
    $(document).ready(function () {
        $('#table-usuarios').DataTable({
            "order": [[0, "desc"]],
            "pageLength": 25,
            "lengthMenu": [10, 25, 50, 100]
        });

        // Fechar alert
        $('.close-alert').click(function () {
            $(this).parent().fadeOut();
        });

        // Duplo clique para editar
        $('#table-usuarios tbody').on('dblclick', 'tr', function () {
            var id = $(this).find('td:first').text().trim();
            if (id) {
                window.location.href = '/Ticket/Editar/' + id;
            }
        });
    });
</script>

<style>
    .form-container {
        padding: 1rem;
        background-color: #f8f9fa;
        border-radius: 10px;
    }
    .table th, .table td {
        font-size: 14px;
        vertical-align: middle;
    }

    .form-container {
        width: 100%;
        margin: 0;
        padding: 0.5rem;
        border: 1px solid #ccc;
        border-radius: 10px0; /* opcional: remove o arredondamento se quiser bordas quadradas */
        background-color: rgba(248, 249, 250, 0);
        box-sizing: border-box; /* garante que padding não estoure a largura */
    }

    .form-container2 {
        width: 100%;
        margin: 0;
        padding: 0.5rem;
        border: 1px solid #ccc;
        border-radius: 10px; /* opcional: remove o arredondamento se quiser bordas quadradas */
        background-color: rgba(248, 249, 250, 0);
        box-sizing: border-box; /* garante que padding não estoure a largura */
    }
    /*
                .custom-border {
                    border-bottom: 2px solid black;
                    padding: 0.25rem;
                } */

    .form-group-spacing {
        margin-bottom: 2rem; /* Triplo do padrão (~1.33rem) */
    }

    #table-usuarios {
        table-layout: auto !important;
        width: auto !important;
    }

        #table-usuarios th,
        #table-usuarios td {
            white-space: nowrap; /* impede quebra de linha */
            font-size: 12px; /* já reduz o tamanho da fonte */
            padding: 4px 8px; /* opcional: deixa a célula mais compacta */
        }

    .icon-mini {
        font-size: 1.05rem; /* ~12px */
    }

    .botao-transparente {
        background-color: transparent;
        border: 1px solid transparent;
        color: black;
    }

        .botao-transparente:hover {
            border-color: black;
            background-color: rgba(0, 0, 0, 0.05);
        }
</style>
