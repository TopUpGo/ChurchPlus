<!DOCTYPE html>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - NHC</title>

        <link href="~/Content/Site.css" rel="stylesheet" />
        <link rel="manifest" href="~/manifest.json" />
        <meta name="theme-color" content="#0d6efd" />
        <link rel="stylesheet" href="~/css/site.css" />

        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/Analise.styles.css" asp-append-version="true" />
        <link href="https://cdn.datatables.net/v/dt/dt-2.2.1/datatables.min.css" rel="stylesheet">

        @RenderSection("Styles", required: false)
    </head>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js')
                    .then(reg => console.log('Service Worker registrado:', reg))
                    .catch(err => console.log('Erro no Service Worker:', err));
            });
        }
    </script>
    <body>
        <div id="global-loader" style="display:none;">
            <div class="loader-backdrop"></div>
            <div class="loader-box">
                <div class="spinner"></div>
                <div class="loader-text">A processar...</div>
            </div>
        </div>

        <header class="site-header">
            <nav class="nav">
                @await Component.InvokeAsync("Menu")
            </nav>
        </header>

        <div class="page-container">
            <section class="page-body">
                @RenderBody()
            </section>

            <footer class="footer">
                &copy; 2025 - TopUp Go
            </footer>
        </div>

       @*  <div class="page-body">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
        <footer class="border-top site-footer text-muted">
            &copy; 2025 - Stely Business
        </footer> *@

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.datatables.net/v/dt/dt-2.2.1/datatables.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)

    <script>
        function mostrarLoader() {
            document.getElementById("global-loader").style.display = "block";
        }

        function esconderLoader() {
            document.getElementById("global-loader").style.display = "none";
        }

        document.addEventListener("DOMContentLoaded", function () {

            // Loader ao submeter formulários
            document.querySelectorAll("form").forEach(function (form) {
                form.addEventListener("submit", function () {
                    mostrarLoader();
                });
            });

            // Loader ao clicar links
            document.querySelectorAll("a").forEach(function (link) {
                link.addEventListener("click", function () {

                    if (link.classList.contains("submenu-toggle"))
                        return;

                    const href = link.getAttribute("href");
                    if (!href || href.startsWith("javascript"))
                        return;

                    mostrarLoader();

                    // 👇 Se abrir nova aba (PDF)
                    if (link.getAttribute("target") === "_blank") {
                        setTimeout(esconderLoader, 2000);
                    }
                });
            });

            // 👇 Quando voltar para a página
            window.addEventListener("focus", function () {
                esconderLoader();
            });

        });
    </script>

    </body>
</html>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-p6gH2IHzxxGzj2vDghXb6A0rR6B5H0KKU+IDkCVS1HOk4/4T7fpOM7V0x6B1yK1pYoT5xVZ4QF5wFz0oh7ktxw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
