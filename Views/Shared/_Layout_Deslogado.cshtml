<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>@ViewBag.Title - Church+</title>
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link href="~/Content/site.css" rel="stylesheet" />
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/Analise.styles.css" asp-append-version="true" />
        <link href="https://cdn.datatables.net/v/dt/dt-2.2.1/datatables.min.css" rel="stylesheet">
   
    </head>
    <body>
        <div class="page-container">
            <section class="page-body">
                @RenderBody()
            </section>

            <footer class="footer">
                &copy; 2025 - TopUp Go
            </footer>
        </div>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.datatables.net/v/dt/dt-2.2.1/datatables.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>

<style>
  /* ============================
   RESET E BASE
============================ */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html, body {
    height: 100%;
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial;
}

/* ============================
   BODY E FUNDO
============================ */
body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        color: #e6f3ea;
        /* background: radial-gradient(ellipse at center, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.75) 70%, rgba(0,0,0,0.9) 100%), linear-gradient(135deg, rgba(6,60,37,0.55) 0%, rgba(15,50,35,0.6) 40%, rgba(10,20,12,0.75) 100%), url('/images/fundo.png'); */
        background: rgba(255,255,255);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        padding-bottom: 50px;
}

body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: 
        radial-gradient(1200px 600px at 85% 30%, rgba(72,196,120,0.08), transparent 10%), 
        radial-gradient(900px 400px at 10% 70%, rgba(10,40,20,0.18), transparent 20%);
    mix-blend-mode: overlay;
    filter: blur(6px);
    z-index: 0;
}

/* ============================
   CONTEÚDO PRINCIPAL
============================ */
.page-container {
    display: flex;
    flex-direction: column;
    flex: 1; /* ocupa o espaço total disponível */
    position: relative;
    z-index: 1;
    padding-bottom: 50px;
}

.page-body {
    flex: 1; /* empurra o rodapé para o fim */
    padding: 50px;
}

/* ============================
   RODAPÉ
============================ */
    /* footer.footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        text-align: center;
        padding: 10px;
        background: rgba(0,0,0,0);
        color: #fff;
    } */

    footer.footer {
        text-align: center;
        padding: 1px;
        background: transparent;
        colo: rgba(0,0,0);
        margin-top: auto;
    }

/* ============================
   CABEÇALHO E HERO
============================ */
.site-header {
    position: relative;
    z-index: 2;
    padding: 18px 36px;
}

.hero-inner::after {
    content: "";
    position: absolute;
    right: -40px;
    top: 40px;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    border: 3px solid rgba(255,255,255,0.03);
    box-shadow: 
        0 30px 90px rgba(0,0,0,0.45),
        inset 0 0 40px rgba(80,200,120,0.03);
    z-index: 1;
    pointer-events: none;
}

/* ============================
   RESPONSIVIDADE
============================ */
@@media (max-width:900px) {
    .hero h1 {
        font-size: 32px;
    }

    .nav-links {
        display: none;
    }

    .hero {
        padding: 30px;
    }

    .cards {
        flex-direction: column;
    }
}

</style>