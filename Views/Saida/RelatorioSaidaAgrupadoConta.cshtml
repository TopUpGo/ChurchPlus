@model SaidaViewModel
@{
    ViewData["Title"] = "Relatórios";
}
<style>
    .form-container {
        width: 100%;
        padding: 0.1rem;
        border: 1px solid #ccc;
        border-radius: 10px; /* opcional: remove o arredondamento se quiser bordas quadradas */
        box-sizing: border-box; /* garante que padding não estoure a largura */
        background-color: rgba(248, 249, 250, 0);
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    /*
                .custom-border {
                    border-bottom: 2px solid black;
                    padding: 0.25rem;
                } */

    .form-group-spacing {
        margin-bottom: 2rem; /* Triplo do padrão (~1.33rem) */
    }

    #table-usuarios {
        table-layout: auto !important;
        width: auto !important;
    }

        #table-usuarios th,
        #table-usuarios td {
            white-space: nowrap; /* impede quebra de linha */
            font-size: 12px; /* já reduz o tamanho da fonte */
            padding: 4px 8px; /* opcional: deixa a célula mais compacta */
            color: rgba(0,0,0); /* branco */
        }

        #table-usuarios thead th {
            color: rgba(0,0,0); /* branco esverdeado */
            font-weight: 600;
        }

    .icon-mini {
        font-size: 1.05rem; /* ~12px */
    }

        .icon-mini:hover {
            border-color: #fff; /* borda branca no hover */
            cursor: pointer; /* muda o cursor para indicar clique */
        }

    .botao-transparente {
        background-color: transparent;
        border: 1px solid transparent;
        color: #fff; /* cor do ícone branco */
    }

        .botao-transparente:hover {
            border-color: #fff; /* cor do ícone branco */
            background-color: rgba(0, 0, 0, 0.05);
        }
    /* reset simples */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        height: 100%;
    }


    /* BOTÃO NAV */
    .btn-nav {
        padding: 6px 14px;
        border-radius: 10px;
        display: inline-block;
        width: 100%;
        text-align: center;
        font-weight: 600;
        border: 1px solid rgba(230,243,234,0.3);
        backdrop-filter: blur(6px);
        background: linear-gradient(90deg, rgba(70,200,120,0.1), rgba(50,160,90,0.14));
        color: #fff;
        cursor: pointer;
        transition: background 0.3s ease, color 0.3s ease;
    }

        .btn-nav:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }

    /* Formulário */
    .form-container {
        width: 100%;
        margin: 0;
        padding: 0.5rem;
        border-radius: 10px;
        background-color: transparent;
        box-sizing: border-box;
    }

    .form-group-spacing {
        margin-bottom: 2rem;
    }

    /* HERO (conteúdo em primeiro plano) */
    .hero {
        min-height: 72vh;
        display: flex;
        align-items: center;
        position: relative;
        z-index: 1;
        padding: 60px 40px;
    }

    .hero-inner {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 32px;
        position: relative;
        z-index: 3;
    }

    .hero h1 {
        font-size: 48px;
        line-height: 1.02;
        margin-bottom: 12px;
        color: #e9fff1;
        text-shadow: 0 6px 22px rgba(2,10,6,0.5);
    }

    .hero .accent {
        color: #48c878;
    }

    .lead {
        color: rgba(230,243,234,0.8);
        margin-bottom: 18px;
    }

    .hero-cta {
        display: flex;
        gap: 12px;
        margin-bottom: 22px;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(6px);
    }

        .btn:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }

        .btn.primary {
            background: rgba(0,0,0);
            color: #eaffef;
        }

            .btn.primary:hover {
                background: rgba(70,200,120,0.18);
                color: rgba(0,0,0);
                border: 1px solid rgba(0,0,0);
            }

        .btn.ghost {
            background: transparent;
            color: rgba(230,243,234,0.9);
            border: 1px solid rgba(230,243,234,0.08);
        }

            .btn.ghost:hover {
                background: rgba(255,255,255,0.05);
                color: rgba(0,0,0);
                border: 1px solid rgba(0,0,0);
            }

    /* cards */
    .cards {
        display: flex;
        gap: 14px;
        margin-top: 18px;
    }

    .card {
        min-width: 200px;
        padding: 14px;
        border-radius: 12px;
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.12));
        box-shadow: 0 8px 24px rgba(2,10,6,0.45);
        backdrop-filter: blur(6px);
        color: #dff7e8;
    }

    /* rodapé */
    .site-footer {
        padding: 24px;
        text-align: center;
        color: rgba(200,230,210,0.6);
    }

    /* responsividade simples */
    @@media (max-width:900px) {
        .hero h1 {
            font-size: 32px;
        }

        .nav-links {
            display: none;
        }

        .hero {
            padding: 30px;
        }

        .cards {
            flex-direction: column;
        }
    }

    /* textbox */
    .textbox {
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 400;
        border: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(6px);
        background: transparent;
        color: #fff;
        font-family: inherit;
        font-size: 16px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.3s ease;
    }

        /* placeholder */
        .textbox::placeholder {
            color: rgba(255,255,255,0.5);
        }

        /* foco */
        .textbox:focus {
            outline: none;
            border: 1px solid #48c878;
            box-shadow: 0 0 12px rgba(72,200,120,0.3);
        }

    /* autocomplete transparente Chrome/Safari */
    input.textbox:-webkit-autofill,
    input.textbox:-webkit-autofill:hover,
    input.textbox:-webkit-autofill:focus,
    input.textbox:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0px 1000px transparent inset !important;
        -webkit-text-fill-color: #fff !important;
        transition: background-color 5000s ease-in-out 0s;
    }

    /* autocomplete transparente Firefox */
    input.textbox:-moz-autofill {
        box-shadow: 0 0 0px 1000px transparent inset !important;
        -moz-text-fill-color: #fff !important;
    }

    /* link verde */
    .link-green {
        color: #48c878;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        transition: color 0.3s ease;
    }

        .link-green:hover {
            color: #32a060;
        }

    /* Combobox estilo igual ao textbox */
    .selectbox {
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 400;
        border: 1px solid rgba(150,150,150);
        backdrop-filter: blur(6px);
        background: transparent;
        color: rgba(0,0,0);
        font-family: inherit;
        font-size: 16px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.3s ease;
        appearance: none; /* remove a setinha padrão */
        -webkit-appearance: none; /* Safari/Chrome */
        -moz-appearance: none; /* Firefox */
        cursor: pointer;
    }

        /* Ícone de seta customizado */
        .selectbox::-ms-expand {
            display: none; /* remove seta no IE */
        }

        /* Opções do dropdown */
        .selectbox option {
            background-color: rgba(20, 20, 20, 0.95); /* fundo escuro */
            color: #fff; /* texto branco */
        }

        /* Foco */
        .selectbox:focus {
            outline: none;
            border: 1px solid #48c878;
            box-shadow: 0 0 12px rgba(72,200,120,0.3);
        }

    .floating-menu {
        display: none; /* começa escondido */
        position: absolute;
        top: 50px; /* distância do botão */
        left: 0; /* alinha à esquerda */
        background-color: white;
        border: 1px solid #ccc;
        border-radius: 5px;
        padding: 5px;
        z-index: 1000;
        width: 150px;
    }

        .floating-menu button,
        .floating-menu a {
            color: gray; /* cor padrão */
            text-decoration: none; /* remove sublinhado do <a> */
            transition: color 0.2s;
            display: block; /* garante largura completa */
        }

            .floating-menu button:hover,
            .floating-menu a:hover {
                color: black; /* cor ao passar o mouse */
                cursor: pointer;
            }

    .menu-container {
        position: relative;
        display: inline-block;
    }

    .btn-menu {
        background: #1f3c88;
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-menu:hover {
            background: #162f6b;
        }

    .floating-menu {
        display: none;
        position: absolute;
        top: 50px;
        left: 0;
        width: 260px;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        padding: 10px;
        z-index: 999;
        animation: fadeIn 0.2s ease-in-out;
    }

    .menu-item {
        margin-bottom: 8px;
    }

    .menu-title {
        font-weight: 600;
        padding: 8px;
        cursor: pointer;
        border-radius: 6px;
        transition: 0.2s;
    }

        .menu-title:hover {
            background: #f1f3f5;
        }

    .submenu {
        display: none;
        padding-left: 10px;
        margin-top: 5px;
    }

        .submenu a {
            display: block;
            padding: 6px 8px;
            text-decoration: none;
            color: #333;
            border-radius: 6px;
            font-size: 14px;
            transition: 0.2s;
        }

            .submenu a:hover {
                background: #e9ecef;
            }

    .menu-link {
        display: block;
        padding: 8px;
        text-decoration: none;
        color: #333;
        font-weight: 500;
        border-radius: 6px;
    }

        .menu-link:hover {
            background: #f1f3f5;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<div class="text-center">

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>
    }
</div>

<div class="menu-container">
    <button id="btnMenu" class="btn-menu">
        📊 Relatórios
    </button>

    <div id="menuFlutuante" class="floating-menu">

        <!-- ENTRADAS -->
        <div class="menu-item">
            <div class="menu-title">Entradas ▾</div>
            <div class="submenu">
                <a asp-controller="Entrada" asp-action="RelatorioEntradas">Geral</a>
                <a asp-controller="Entrada" asp-action="RelatorioEntradaAgrupadoTab">Por Tabernáculo</a>
                <a asp-controller="Entrada" asp-action="RelatorioEntradaAgrupadoTipo">Por Tipo</a>
                <a asp-controller="Entrada" asp-action="RelatorioEntradaAgrupadoConta">Por Conta</a>
                <a asp-controller="Entrada" asp-action="RelatorioEntradaAgrupadoLinha">Por Linha</a>
            </div>
        </div>

        <!-- SAÍDAS -->
        <div class="menu-item">
            <div class="menu-title">Saídas ▾</div>
            <div class="submenu">
                <a asp-controller="Saida" asp-action="RelatorioSaidas">Geral</a>
                <a asp-controller="Saida" asp-action="RelatorioSaidaAgrupadoTab">Por Tabernáculo</a>
                <a asp-controller="Saida" asp-action="RelatorioSaidaAgrupadoTipo">Por Tipo</a>
                <a asp-controller="Saida" asp-action="RelatorioSaidaAgrupadoConta">Por Conta</a>
                <a asp-controller="Saida" asp-action="RelatorioSaidaAgrupadoLinha">Por Linha</a>
            </div>
        </div>

        <!-- FECHO -->
        <div class="menu-item">
            <a class="menu-link" asp-controller="Fecho" asp-action="Relatorio">
                Fecho Geral
            </a>
        </div>

    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="text-center mb-5">
            <h1 class="fs-3 custom-border d-inline-block">Relatórios de Saídas por Conta</h1>
        </div>
        <!-- 🔹 LADO ESQUERDO – FORMULÁRIO -->
        <div class="col-md-5">
           
            <form asp-action="RelatorioSaidaAgrupadoConta" method="get">
                
                <div class="row form-group-spacing align-items-center">
                    <!-- BOTÕES -->
                    <div class="row form-group-spacing">
                        <div class="col-12 col-sm-10 offset-sm-4 d-flex gap-2 mt-4">
                            <button type="submit" class="btn ghost">
                                🔍
                            </button>

                            <a target="_blank"
                               asp-action="ImprimirSaidaAgrupadoConta"
                               asp-controller="Saida"
                               asp-route-dataInicio="@Context.Request.Query["dataInicio"]"
                               asp-route-dataFim="@Context.Request.Query["dataFim"]"
                               class="btn ghost">
                               ⬇️
                            </a>

                            <a asp-action="RelatorioSaidaAgrupadoConta" class="btn ghost">
                               ❌
                            </a>
                        </div>
                    </div>

                    <!-- DATA INICIAL -->
                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Data inicial</label>
                        <div class="col-12 col-sm-6">
                            <input type="date"
                                   name="dataInicio"
                                   value="@Context.Request.Query["dataInicio"]"
                                   class="form-control" />
                        </div>
                    </div>

                    <!-- DATA FINAL -->
                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Data final</label>
                        <div class="col-12 col-sm-6">
                            <input type="date"
                                   name="dataFim"
                                   value="@Context.Request.Query["dataFim"]"
                                   class="form-control" />
                        </div>
                    </div>

                </div>
            </form>
        </div>


        <!-- 🔹 LADO DIREITO – TABELA -->
        <div class="col-md-7">
            <div class="form-container">
                <table class="table" id="table-usuarios">
                    <thead>
                        <tr>
                            <th scope="col">Conta</th>
                            <th scope="col">Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.ListaSaidas.Any())
                        {
                            foreach (SaidaModel cargo in Model.ListaSaidas)
                            {
                                <tr>                                    
                                    <td>@cargo.Conta.Nome</td>
                                    <td class="text-end">@cargo.Valor.ToString("N2")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr class="odd"><td valign="top" colspan="2">Nenhum dado encontrado</td></tr>
                        }
                    </tbody>
                </table>

                <div id="modalContactosUsuario" class="modal" tabindex="-1">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Lista de contactos</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div id="listaContactoUsuario"></div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<script>
    const btnMenu = document.getElementById("btnMenu");
     const menu = document.getElementById("menuFlutuante");

     btnMenu.addEventListener("click", () => {
         menu.style.display = menu.style.display === "block" ? "none" : "block";
     });

     document.querySelectorAll(".menu-title").forEach(title => {
         title.addEventListener("click", function () {
             const submenu = this.nextElementSibling;
             submenu.style.display =
                 submenu.style.display === "block" ? "none" : "block";
         });
     });

     // Fecha ao clicar fora
     document.addEventListener("click", function (e) {
         if (!e.target.closest(".menu-container")) {
             menu.style.display = "none";
         }
     });
</script>